# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/htc_community?schema=public"

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-real-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
